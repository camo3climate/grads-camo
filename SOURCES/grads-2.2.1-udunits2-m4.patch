Description: make the udunits autoconf macro use udunits2
Author: Codex packaging helper
Forwarded: no

--- a/m4/udunits.m4
+++ b/m4/udunits.m4
@@ -102,9 +102,9 @@
   ac_udunits_save_LIBS=$LIBS

   ac_udunits_lib='no'
-  AC_CHECK_LIB_NOCACHE_UDUNITS([udunits],[main],
+  AC_CHECK_LIB_NOCACHE_UDUNITS([udunits2],[utInit],
   [ ac_udunits_lib="yes"
-    UDUNITS_LIBS="-ludunits $UDUNITS_LIBS"
