+static gaint gaset_panel (char *cmd, struct gacmn *pcm) {
+gaint panel,row,col;
+gadouble pw,ph,xlo,xhi,ylo,yhi;
+
+  if (cmd==NULL) {
+    gaprnt(0,"SET PANEL Error: missing panel number\n");
+    return(1);
+  }
+  if (intprs(cmd,&panel) == NULL) {
+    gaprnt(0,"SET PANEL Error: invalid panel number\n");
+    return(1);
+  }
+  if (panel<1 || panel>panel_rows*panel_cols) {
+    gaprnt(0,"SET PANEL Error: panel number is outside the current layout\n");
+    return(1);
+  }
+  row = (panel-1) / panel_cols;
+  col = (panel-1) % panel_cols;
+  pw = (pcm->pxsize - panel_gap*(gadouble)(panel_cols-1)) / (gadouble)panel_cols;
+  ph = (pcm->pysize - panel_gap*(gadouble)(panel_rows-1)) / (gadouble)panel_rows;
+  if (pw<=0.0 || ph<=0.0) {
+    gaprnt(0,"SET PANEL Error: panel gap is too large\n");
+    return(1);
+  }
+  xlo = (gadouble)col * (pw + panel_gap);
+  xhi = xlo + pw;
+  yhi = pcm->pysize - (gadouble)row * (ph + panel_gap);
+  ylo = yhi - ph;
+  pcm->xsiz = pw;
+  pcm->ysiz = ph;
+  pcm->paflg = 0;
+  pcm->pass = 0;
+  gxvpag (pcm->xsiz, pcm->ysiz, xlo, xhi, ylo, yhi);
+  snprintf(pout,1255,"panel = %i (%i x %i)\n",panel,panel_rows,panel_cols);
+  gaprnt(2,pout);
+  return(0);
+}
 
+static gaint gaset_panels (char *cmd, struct gacmn *pcm) {
+gaint rows,cols;
+gadouble gap;
+
+  if (cmd==NULL) {
+    gaprnt(0,"SET PANELS Error: missing row count\n");
+    return(1);
+  }
+  if (cmpwrd("off",cmd) || cmpwrd("reset",cmd)) {
+    panel_rows = 1;
+    panel_cols = 1;
+    panel_gap = 0.12;
+    pcm->xsiz = pcm->pxsize;
+    pcm->ysiz = pcm->pysize;
+    pcm->paflg = 0;
+    pcm->pass = 0;
+    gxvpag (pcm->xsiz, pcm->ysiz, 0.0, pcm->xsiz, 0.0, pcm->ysiz);
+    gaprnt(2,"panels = off\n");
+    return(0);
+  }
+  if (intprs(cmd,&rows) == NULL) {
+    gaprnt(0,"SET PANELS Error: invalid row count\n");
+    return(1);
+  }
+  cmd = nxtwrd(cmd);
+  if (cmd==NULL || intprs(cmd,&cols) == NULL) {
+    gaprnt(0,"SET PANELS Error: invalid column count\n");
+    return(1);
+  }
+  gap = 0.12;
+  if ((cmd=nxtwrd(cmd)) != NULL) {
+    if (getdbl(cmd,&gap) == NULL) {
+      gaprnt(0,"SET PANELS Error: invalid gap\n");
+      return(1);
+    }
+  }
+  if (rows<1 || rows>9 || cols<1 || cols>9 || gap<0.0) {
+    gaprnt(0,"SET PANELS Error: rows/columns must be 1-9 and gap must be non-negative\n");
+    return(1);
+  }
+  panel_rows = rows;
+  panel_cols = cols;
+  panel_gap = gap;
+  snprintf(pout,1255,"panels = %i x %i gap %g\n",panel_rows,panel_cols,panel_gap);
+  gaprnt(2,pout);
+  return gaset_panel("1",pcm);
+}
+
+static gaint gaset_rgbmap (char *cmd, struct gacmn *pcm) {
+gaint p,i,j,start,rev;
+char *name;
+
+  name = cmd;
+  if (name==NULL) {
+    gaprnt(0,"SET RGBMAP Error: missing palette name\n");
+    return(1);
+  }
+  p = -1;
+  for (i=0; i<4; i++) {
+    if (cmpwrd(palettes[i].name,name)) p = i;
+  }
+  if (p<0) {
+    gaprnt(0,"SET RGBMAP Error: valid palettes are viridis, plasma, magma, cividis\n");
+    return(1);
+  }
+  start = 16;
+  rev = 0;
+  while ((cmd = nxtwrd(cmd)) != NULL) {
+    if (cmpwrd("reverse",cmd) || cmpwrd("rev",cmd)) rev = 1;
+    else {
+      if (intprs(cmd,&start) == NULL) {
+        gaprnt(0,"SET RGBMAP Error: expected color number or reverse\n");
+        return(1);
+      }
+    }
+  }
+  if (start<16 || start>2036) {
+    gaprnt(0,"SET RGBMAP Error: start color must be between 16 and 2036\n");
+    return(1);
+  }
+  for (i=0; i<13; i++) {
+    j = rev ? 12-i : i;
+    gxacol(start+i, palettes[p].red[j], palettes[p].green[j], palettes[p].blue[j], 255);
+    pcm->rbcols[i] = start+i;
+  }
+  pcm->rbflg = 13;
+  snprintf(pout,1255,"rgbmap %s loaded into colors %i-%i; rainbow colors now use this palette\n",
+           palettes[p].name,start,start+12);
+  gaprnt(2,pout);
+  return(0);
+}
