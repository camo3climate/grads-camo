+    pcm->grflag = 1;
+    pcm->grstyl = 1;
+    pcm->grcolr = 15;
+    pcm->grthck = 1;
+    pcm->mapcol = 15;
+    pcm->mapstl = 1;
+    pcm->mapthk = 2;
+    pcm->aaflg = 1;
+    gxsignal(3);
+    gaprnt(2,"theme = modern\n");
+    return(0);
+  }
+  gaprnt(0,"SET THEME Error: valid themes are classic or modern\n");
+  return(1);
+}
