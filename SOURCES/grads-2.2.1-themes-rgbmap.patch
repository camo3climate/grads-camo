+    pcm->mapthk = 1;
+    gaprnt(2,"theme = classic\n");
+    return(0);
+  }
+  if (cmpwrd("modern",cmd)) {
+    gxsetllasp(1.0);
+    if (dsubs && psubs && dsubs->gxdckfont()!=0 && psubs->gxpckfont()!=0) {
+      gxdbsethersh(1);
+      gxchdf(0);
